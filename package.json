{
  "name": "intent-gate-armoriq-assignment",
  "version": "1.0.0",
  "private": true,
  "description": "Guarded AI agent with live MCP discovery, policy enforcement, approval flow, and audit logs.",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "tsx watch --clear-screen=false apps/api/src/server.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "start": "tsx apps/api/src/server.ts",
    "test": "vitest run --config vitest.config.ts",
    "mcp:custom": "tsx apps/custom-mcp-server/src/server.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "keywords": [
    "armoriq",
    "mcp",
    "agent-security",
    "intent-assurance"
  ],
  "author": "Divyansh",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "^5.1.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^0.562.0",
    "openai": "^6.10.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "uuid": "^13.0.0",
    "vite": "^7.3.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "esbuild": "^0.28.0"
  }
}
